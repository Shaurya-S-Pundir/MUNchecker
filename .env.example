# ─── Google Sheets ─────────────────────────────────────────────────────────────
# The ID of your Google Sheet (found in the URL: /d/<SHEET_ID>/edit)
GOOGLE_SHEET_ID=1rQNgxXh6IAexMKCnRX0GmHfeGQmNzDWfrfSfFlSm-I0

# The name of the tab/sheet to search. Leave blank to search ALL tabs automatically.
# Set to a specific name (e.g. "LOK SABHA") to restrict to one committee.
GOOGLE_SHEET_TAB_NAME=

# ─── Google Service Account ────────────────────────────────────────────────────
# Paste the entire service account JSON as a single line string.
# Get this from: Google Cloud Console → IAM & Admin → Service Accounts → Keys
# Important: Share your Google Sheet with the service account email first!
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-service-account@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com"}
